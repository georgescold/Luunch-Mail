# ============================================================================
# Luunch Mail — variables d'environnement
# Copiez ce fichier en `.env` puis ajustez. L'app démarre SANS aucune clé
# externe grâce au MODE DÉMO (events d'envoi simulés). Renseignez les clés
# pour activer l'envoi réel et les intégrations.
# ============================================================================

# --- Base de données ---------------------------------------------------------
# Dev : SQLite (zéro config). Prod : remplacez par une URL Postgres et changez
# `provider = "postgresql"` dans prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# --- Sécurité ----------------------------------------------------------------
# Secret de signature des sessions et des webhooks (générez une longue chaîne aléatoire).
APP_SECRET="dev-secret-change-me-please-use-a-long-random-string"
APP_URL="http://localhost:3000"

# --- Mode d'envoi ------------------------------------------------------------
# "demo"   : aucun e-mail réel envoyé, les events (delivered/open/click) sont simulés.
# "resend" : envoi réel via l'API Resend (nécessite RESEND_API_KEY).
# "smtp"   : envoi réel via un relais SMTP (nécessite les SMTP_* ci-dessous).
EMAIL_PROVIDER="demo"

# --- Resend (transactionnel & broadcasts réels) -----------------------------
# https://resend.com/api-keys
RESEND_API_KEY=""
# Domaine vérifié d'envoi par défaut (ex: "no-reply@votredomaine.com")
DEFAULT_FROM_EMAIL="no-reply@luunchmail.local"

# --- SMTP générique (alternatif à Resend) -----------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"

# --- OAuth Google Workspace / Gmail (connexion réelle des boîtes) -----------
# Créez un "ID client OAuth" (type Application Web) sur Google Cloud Console,
# activez l'API Gmail, et ajoutez cette URI de redirection autorisée :
#   http://localhost:3000/api/oauth/google/callback
# Guide pas-à-pas : voir docs/SETUP-GOOGLE.md
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Microsoft 365 / Outlook (à venir)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# --- DNS automatisé (provisioning domaines) ---------------------------------
# Cloudflare API pour poser/vérifier SPF/DKIM/DMARC/MX/CNAME automatiquement.
CLOUDFLARE_API_TOKEN=""

# --- IA (agents, composer, agent de réponse) --------------------------------
# Une seule des deux suffit. Sans clé : l'IA tourne en mode démo (réponses gabarit).
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# Modèle Claude par défaut (recommandé)
ANTHROPIC_MODEL="claude-opus-4-8"

# --- Tracking des ouvertures / clics -------------------------------------
# Domaine dédié aux liens trackés et au pixel (optionnel, recommandé en prod).
# Créez un CNAME track.votredomaine.com -> votre app, puis :
# TRACKING_DOMAIN=track.votredomaine.com
